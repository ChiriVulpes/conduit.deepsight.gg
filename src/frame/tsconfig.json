{
	"compilerOptions": {
		"strict": true,
		"target": "ES2024",
		"lib": ["ES2024", "DOM", "DOM.Iterable", "ESNext.Iterator", "WebWorker"],
		"moduleResolution": "node",
		"outDir": "../../out/service",
		"declarationDir": "../client/frame",
		"module": "commonjs",
		"baseUrl": ".",
		"types": [],
		"incremental": true,
		"composite": true,
		"esModuleInterop": true,
		"noImplicitOverride": true,
		"experimentalDecorators": true,
		"forceConsistentCasingInFileNames": true,
		"noUnusedLocals": true,
		"allowJs": true,
		"skipLibCheck": true,
		"noErrorTruncation": true,
		"preserveSymlinks": true,
		"paths": {
			"@shared/*": [
				"../shared/*"
			],
			"bungie-api-ts": [
				"../../node_modules/bungie-api-ts/index.d.ts"
			],
			"bungie-api-ts/*": [
				"../../node_modules/bungie-api-ts/*"
			],
			"deepsight.gg": [
				"../../node_modules/deepsight.gg/Interfaces.d.ts"
			],
			"deepsight.gg/*": [
				"../../node_modules/deepsight.gg/*"
			],
		}
	},
	"references": [
		{"path": "../shared" }
	],
	"include": [
		"**/*.ts"
	]
}
